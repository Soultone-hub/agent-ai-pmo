# ── Base de données PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://pmo_user:pmo_password@localhost:5432/pmo_db

# ── LLM Groq ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_votre_cle_api_ici

# ── ChromaDB (stockage vectoriel) ─────────────────────────────────────────────
CHROMA_PATH=./chroma_db

# ── Sécurité JWT ──────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-cette-valeur-en-production-avec-une-cle-aleatoire-longue

# Algorithme JWT (ne pas modifier)
JWT_ALGORITHM=HS256

# Durée de validité du token d'accès (en minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Durée de validité du refresh token (en jours)
REFRESH_TOKEN_EXPIRE_DAYS=7